{
  "name": "pi-goal-driven",
  "version": "0.4.0",
  "description": "Goal-Driven template workflow for pi",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/vurihuang/pi-goal-driven.git"
  },
  "homepage": "https://github.com/vurihuang/pi-goal-driven#readme",
  "bugs": {
    "url": "https://github.com/vurihuang/pi-goal-driven/issues"
  },
  "keywords": [
