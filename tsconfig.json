{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "pi-subagents/agents.ts": ["./shims/pi-subagents-agents.d.ts"],
      "pi-subagents/types.ts": ["./shims/pi-subagents-types.d.ts"],
      "pi-subagents/execution.ts": ["./shims/pi-subagents-execution.d.ts"],
      "pi-subagents/text-editor.ts": ["./shims/pi-subagents-text-editor.d.ts"],
      "pi-subagents/utils.ts": ["./shims/pi-subagents-utils.d.ts"]
    },
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true
  },
  "include": ["index.ts", "shims/**/*.d.ts"]
}
